# ----- SumUp Online Payments -----
# API-Key aus dem SumUp-Dashboard (Developer → API Keys), beginnt mit "sup_sk_..."
SUMUP_API_KEY=sup_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Merchant Code des Restaurants (im SumUp-Dashboard unter "Mein Konto" zu finden)
SUMUP_MERCHANT_CODE=MXXXXXXX

# ----- WhatsApp via CallMeBot -----
# Internationale Telefonnummer ohne "+" und ohne Leerzeichen (z.B. 4915112345678)
WHATSAPP_PHONE=4915112345678

# CallMeBot API-Key — der Restaurant-Inhaber muss einmal die Nachricht
# "I allow callmebot to send me messages" an +34 644 51 95 23 schicken
# und bekommt dann seinen persönlichen Key per WhatsApp zurück.
WHATSAPP_API_KEY=123456

# ----- Site -----
# Vollständige URL deiner deployten Seite (für return_url / redirect_url).
# Lokal: http://localhost:3000 (SumUp kann aber localhost nicht erreichen — für
# echte Tests deployen oder ngrok nutzen)
NEXT_PUBLIC_SITE_URL=https://amicizia.example.com
